# MineralForge runtime configuration

# Default mine zone used by app.py or deployment wrappers.
MINERALFORGE_ZONE=Stope 3

# Synthetic demo stress multiplier. Higher values create more severe examples.
MINERALFORGE_STRESS_MULTIPLIER=2.8

# Optional future hardware configuration.
ACOUSTIC_SAMPLE_RATE_HZ=1000
VIBRATION_SAMPLE_RATE_HZ=1000
