# JR MineralForge .gitignore

# ── Python ──────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
env/
venv/
.venv/
ENV/
pip-wheel-metadata/

# ── Environment ─────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.env

# ── Data (large downloads — do not commit) ───────────────────────
data/raw/
data/processed/
data/vector_store/
data/winners_knowledge/

# ── Model artifacts ─────────────────────────────────────────────
models/
mlflow_runs/

# ── Logs ─────────────────────────────────────────────────────────
logs/
*.log

# ── Reports (generated outputs) ─────────────────────────────────
reports/
mineralforge_report.html

# ── IDEs ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Jupyter ──────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Testing ──────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
